{
    "task": [
        {
            "name": "英杰试炼",
            "label": "英杰试炼",
            "entry": "英杰试炼",
            "group": ["standalone"],
            "option": [
                "选择试炼英杰",
                "选择试炼目标",
                "英杰试炼阵容预设"
            ]
        }
    ],
    "option": {
        "选择试炼英杰":{
            "type": "select",
            "label": "选择需要试炼英杰",
            "default_case": "源赖光",
            "cases": [
                {
                    "name": "源赖光",
                    "label": "源赖光",
                    "pipeline_override": {
                        "英杰试炼-选中源赖光": {
                            "enable":true
                        },
                       "英杰试炼-点击源赖光": {
                            "enable":true
                        }
                    }
                },
                {
                    "name": "藤原道长",
                    "label": "藤原道长",
                    "pipeline_override": {
                        "英杰试炼-选中藤原道长": {
                            "enable":true
                        },
                       "英杰试炼-点击藤原道长": {
                            "enable":true
                        }
                    }
                }
            ]
        },
        "选择试炼目标":{
            "type": "select",
            "label": "试炼目标",
            "default_case": "技能经验",
            "cases": [
                {
                    "name": "御灵经验",
                    "label": "御灵经验",
                    "pipeline_override": {
                        "英杰试炼-藤原道长-梦墟秘境":{
                            "enable":false
                        },
                        "英杰试炼-源赖光-兵藏秘境":{
                            "enable":false
                        }
                    },
                    "option": ["英杰试炼-是否启用经验加成"]
                },
                {
                    "name": "技能经验",
                    "label": "技能经验",
                    "pipeline_override": {
                        "英杰试炼-藤原道长-传承试炼":{
                            "enable":false
                        },
                        "英杰试炼-源赖光-鬼兵演武":{
                            "enable":false
                        }
                    },
                    "option": ["局内祝福选择"]
                }
            ]
        },
        "英杰试炼阵容预设": {
            "type": "input",
            "label": "英杰试炼阵容预设",
            "description": "填写英杰试炼时需要使用的分组和队伍名称",
            "inputs": [
                {
                    "name": "group_name",
                    "label": "分组预设名称",
                    "description": "填写分组预设名称",
                    "default": "默认分组",
                    "pipeline_type": "string"
                },
                {
                    "name": "team_name",
                    "label": "队伍预设名称",
                    "description": "填写队伍预设名称",
                    "default": "默认队伍",
                    "pipeline_type": "string"
                }
            ],
            "pipeline_override": {
                "英杰试炼-确保位于式神录-装备御魂": {
                    "custom_action_param": {
                        "group_name": "{group_name}",
                        "team_name": "{team_name}"
                    }
                }
            }
        },
        "局内祝福选择": {
            "type": "input",
            "label": "局内祝福选择",
            "description": "填写在局内出现祝福时的选择",
            "inputs": [
                {
                    "name": "目标祝福",
                    "label": "目标祝福",
                    "description": "填写格式为正则,如 万刃|弥天 表示有万刃或者弥天则选择, 填写 万刃 则只选择万刃,没有则选第一个",
                    "default": "万刃|弥天",
                    "pipeline_type": "string"
                }
            ],
            "pipeline_override": {
                "英杰试炼-点击目标祝福": {
                    "expected": "{目标祝福}"
                }
            }
        },
        "英杰试炼-是否启用经验加成":{
            "type": "switch",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "label": "是",
                    "pipeline_override": {
                        "英杰试炼-关闭经验加成":{
                            "enable":true
                        },
                        "英杰试炼-开启经验加成":{
                            "enable":true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "否",
                    "pipeline_override": {
                        "英杰试炼-关闭经验加成":{
                            "enable":false
                        },
                        "英杰试炼-开启经验加成":{
                            "enable":false
                        }
                    }
                }
            ]
        }
    }
}
