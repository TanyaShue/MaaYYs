{
    "task": [
        {
            "name": "自动秘闻",
            "label": "自动秘闻",
            "entry": "自动秘闻",
            "option": [
                "秘闻阵容预设",
                "秘闻分享"
            ]
        }
    ],
    "option": {
        "秘闻分享": {
            "type": "switch",
            "label": "是否分享秘闻(仅支持mumu模拟器)",
            "description": "挑战完10层后,自动分享到微信(不真正进入微信)",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "label": "是",
                    "pipeline_override": {
                        "自动秘闻-分享": {
                            "enable":true
                        }
                    },
                    "option": ["契灵探查阵容"]
                },
                {
                    "name": "No",
                    "label": "否",
                    "pipeline_override": {
                        "自动秘闻-分享": {
                            "enable":false
                        }
                    }
                }
            ]
        },
        "秘闻阵容预设": {
            "type": "input",
            "label": "秘闻阵容预设",
            "description": "填写挑战秘闻副本需要的分组和队伍预设名称",
            "inputs": [
                {
                    "name": "group_name",
                    "label": "分组预设名称",
                    "description": "填写分组预设名称",
                    "default": "默认队伍",
                    "pipeline_type": "string"
                },
                {
                    "name": "team_name",
                    "label": "队伍预设名称",
                    "description": "填写队伍预设名称",
                    "default": "默认队伍",
                    "pipeline_type": "string"
                }
            ],
            "pipeline_override": {
                "自动秘闻_装备式神预设": {
                    "custom_action_param": {
                        "group_name": "{group_name}",
                        "team_name": "{team_name}"
                    }
                }
            }
        }
    }
}
