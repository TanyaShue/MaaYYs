{
    "task": [
        {
            "name": "自动悬赏",
            "label": "自动悬赏",
            "entry": "自动悬赏封印",
            "group": ["standalone"],
            "option": [
                "悬赏目标",
                "悬赏封印阵容预设"
            ]
        }
    ],
    "option": {
        "悬赏目标": {
            "type": "select",
            "label": "悬赏目标",
            "description": "选择自动悬赏时优先打探索副本还是式神挑战券。注意：部分情况可能两者都没有，会导致任务卡住",
            "default_case": "探索优先",
            "cases": [
                {
                    "name": "探索优先",
                    "label": "探索优先",
                    "pipeline_override": {
                        "悬赏封印-判断是否在追踪列表": {
                            "next": [
                                "悬赏封印-判断是否是协战的目标",
                                "悬赏封印-查找探索副本",
                                "悬赏封印-查找式神碎片副本",
                                "悬赏封印-查找秘闻副本",
                                "悬赏封印-向上滑动一点"
                            ]
                        }
                    }
                },
                {
                    "name": "挑战优先",
                    "label": "挑战优先",
                    "pipeline_override": {
                        "悬赏封印-判断是否在追踪列表": {
                            "next": [
                                "悬赏封印-判断是否是协战的目标",
                                "悬赏封印-查找式神碎片副本",
                                "悬赏封印-查找探索副本",
                                "悬赏封印-查找秘闻副本",
                                "悬赏封印-向上滑动一点"
                            ]
                        }
                    }
                }
            ]
        },
        "悬赏封印阵容预设": {
            "type": "input",
            "label": "悬赏封印阵容预设",
            "description": "填写需要挑战悬赏封印的分组和队伍预设名称",
            "inputs": [
                {
                    "name": "group_name",
                    "label": "分组预设名称",
                    "description": "填写分组预设名称",
                    "default": "默认分组",
                    "pipeline_type": "string"
                },
                {
                    "name": "team_name",
                    "label": "队伍预设名称",
                    "description": "填写队伍预设名称",
                    "default": "默认队伍",
                    "pipeline_type": "string"
                }
            ],
            "pipeline_override": {
                "装备日常清杂预设": {
                    "custom_action_param": {
                        "group_name": "{group_name}",
                        "team_name": "{team_name}"
                    }
                }
            }
        }
    }
}
