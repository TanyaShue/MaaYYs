{
    "task": [
        {
            "name": "组队副本",
            "label": "组队副本",
            "entry": "组队副本",
            "option": [
                "组队副本-挑战经验副本",
                "组队副本-挑战金币副本"
            ]
        }
    ],
    "option": {
        "组队副本-挑战金币副本": {
            "type": "switch",
            "label": "组队副本-金币副本",
            "description": "是否在挑战金币副本",
            "cases": [
                {
                    "name": "Yes",
                    "label": "是",
                    "pipeline_override": {
                        "组队副本-开始挑战金币妖怪": {
                            "enabled": true
                        }
                    },
                    "option": [
                        "组队副本-是否启用金币加成",
                        "组队副本-金币副本阵容预设"
                    ]
                },
                {
                    "name": "No",
                    "label": "否",
                    "pipeline_override": {
                        "组队副本-开始挑战金币妖怪": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "组队副本-挑战经验副本": {
            "type": "switch",
            "label": "组队副本-经验副本",
            "description": "是否在挑战经验副本",
            "cases": [
                {
                    "name": "Yes",
                    "label": "是",
                    "pipeline_override": {
                        "组队副本-开始挑战经验妖怪": {
                            "enabled": true
                        }
                    },
                    "option": [
                        "组队副本-是否启用经验加成",
                        "组队副本-经验副本阵容预设"
                    ]
                },
                {
                    "name": "No",
                    "label": "否",
                    "pipeline_override": {
                        "组队副本-开始挑战经验妖怪": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "组队副本-是否启用金币加成": {
            "type": "switch",
            "label": "组队副本-是否启用金币加成",
            "description": "是否启用金币加成",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "label": "是",
                    "pipeline_override": {
                        "组队副本-金币副本-打开加成": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "否",
                    "pipeline_override": {
                        "组队副本-金币副本-打开加成": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "组队副本-是否启用经验加成": {
            "type": "switch",
            "label": "组队副本-是否启用经验加成",
            "description": "是否启用经验加成",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "label": "是",
                    "pipeline_override": {
                        "组队副本-经验副本-打开加成": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "否",
                    "pipeline_override": {
                        "组队副本-经验副本-打开加成": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "组队副本-金币副本阵容预设": {
            "type": "input",
            "label": "金币副本阵容预设",
            "description": "填写金币副本需要使用的分组和队伍预设名称",
            "default": "默认分组",
            "inputs": [
                {
                    "name": "group_name",
                    "label": "分组预设名称",
                    "description": "填写分组预设名称",
                    "default": "默认分组",
                    "pipeline_type": "string"
                },
                {
                    "name": "team_name",
                    "label": "队伍预设名称",
                    "description": "填写队伍预设名称",
                    "default": "默认队伍",
                    "pipeline_type": "string"
                }
            ],
            "pipeline_override": {
                "组队副本-装备金币副本预设": {
                    "custom_action_param": {
                        "group_name": "{group_name}",
                        "team_name": "{team_name}"
                    }
                }
            }
        },
        "组队副本-经验副本阵容预设": {
            "type": "input",
            "label": "经验副本阵容预设",
            "description": "填写经验副本需要使用的分组和队伍预设名称",
            "default": "默认分组",
            "inputs": [
                {
                    "name": "group_name",
                    "label": "分组预设名称",
                    "description": "填写分组预设名称",
                    "default": "默认分组",
                    "pipeline_type": "string"
                },
                {
                    "name": "team_name",
                    "label": "队伍预设名称",
                    "description": "填写队伍预设名称",
                    "default": "默认队伍",
                    "pipeline_type": "string"
                }
            ],
            "pipeline_override": {
                "组队副本-装备经验副本预设": {
                    "custom_action_param": {
                        "group_name": "{group_name}",
                        "team_name": "{team_name}"
                    }
                }
            }
        }
    }
}