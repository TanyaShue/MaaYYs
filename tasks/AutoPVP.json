{
    "task": [
        {
            "name": "自动斗技",
            "label": "自动斗技",
            "entry": "自动斗技-开始时间检查",
            "option": [
                "自动斗技预设",
                "自动斗技-战斗结算界面皮肤"
            ]
        }
    ],
    "option": {
        "自动斗技预设": {
            "type": "input",
            "label": "斗技阵容预设",
            "description": "填写斗技需要的分组和队伍预设名称",
            "inputs": [
                {
                    "name": "group_name",
                    "label": "分组预设名称",
                    "description": "填写分组预设名称",
                    "default": "默认队伍",
                    "pipeline_type": "string"
                },
                {
                    "name": "team_name",
                    "label": "队伍预设名称",
                    "description": "填写队伍预设名称",
                    "default": "默认队伍",
                    "pipeline_type": "string"
                }
            ],
            "pipeline_override": {
                "自动斗技-确保打开式神录并切换御魂": {
                    "custom_action_param": {
                        "group_name": "{group_name}",
                        "team_name": "{team_name}"
                    }
                }
            }
        },
        "自动斗技-战斗结算界面皮肤":{
            "type": "select",
            "label": "结算界面皮肤",
            "description": "不是战斗主题皮肤，是结算界面皮肤，战斗主题皮肤不影响",
            "default_case":"默认",
            "cases":[
                {
                    "name":"默认",
                    "pipeline_override": {
                        "自动斗技-胜利":{
                            "template":[
                                "斗技/胜利.png"
                            ]
                        },
                        "自动斗技-失败":{
                            "template":[
                                "斗技/失败.png"
                            ]
                        }
                    }
                },
                {
                    "name":"招财纳福",
                    "pipeline_override":{
                        
                        "自动斗技-胜利":{
                            "template":[
                                "斗技/胜利-招财纳福.png"
                            ]
                        },
                        "自动斗技-失败":{
                            "template":[
                                "斗技/失败-招财纳福.png"
                            ]
                        }
                    }
                }
            ]
        }
    }
}
