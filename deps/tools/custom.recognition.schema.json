{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "custom_recognition": {
            "enum": [
                "TaskCounterRecognition",
                "MyRecognizer"
            ]
        }
    },
    "anyOf": [
        {
            "$ref": "#/$defs/TaskCounterRecognition"
        },
        {
            "$ref": "#/$defs/MyRecognizer"
        }
    ],
    "$defs": {
        "RequiredParam": {
            "anyOf": [
                {
                    "required": [
                        "custom_recognition_param"
                    ]
                },
                {
                    "required": [
                        "custom_recognition_param_code"
                    ]
                }
            ]
        },
        "TaskCounterRecognition": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_recognition": {
                    "const": "TaskCounterRecognition",
                    "description": "任务计数识别器，每次调用计数加一"
                },
                "custom_recognition_param": {
                    "type": "object",
                    "properties": {
                        "target_count": {
                            "type": "integer",
                            "minimum": 1,
                            "description": "目标次数"
                        }
                    },
                    "required": ["target_count"],
                    "additionalProperties": false
                }
            }
        },
        "MyRecognizer": {
            "properties": {
                "custom_recognition": {
                    "const": "MyRecognizer",
                    "description": "占位/测试识别器"
                }
            }
        }
    }
}