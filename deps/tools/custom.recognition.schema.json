{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "custom_recognition": {
            "enum": [
                "ConfigValueCheckRecognition",
                "ConfigValueWriteRecognition",
                "TaskCounterRecognition",
                "MyRecognizer"
            ]
        }
    },
    "anyOf": [
        {
            "$ref": "#/$defs/ConfigValueCheckRecognition"
        },
        {
            "$ref": "#/$defs/ConfigValueWriteRecognition"
        },
        {
            "$ref": "#/$defs/TaskCounterRecognition"
        },
        {
            "$ref": "#/$defs/MyRecognizer"
        }
    ],
    "$defs": {
        "RequiredParam": {
            "anyOf": [
                {
                    "required": [
                        "custom_recognition_param"
                    ]
                },
                {
                    "required": [
                        "custom_recognition_param_code"
                    ]
                }
            ]
        },
        "ConfigValueCheckRecognition": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_recognition": {
                    "const": "ConfigValueCheckRecognition",
                    "description": "读取根目录 assets 下的 JSON，并按数值比较判断是否返回 true"
                },
                "custom_recognition_param": {
                    "type": "object",
                    "properties": {
                        "key": {
                            "type": "string",
                            "description": "要检查的键名"
                        },
                        "value": {
                            "oneOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "number"
                                },
                                {
                                    "type": "integer"
                                }
                            ],
                            "description": "比较阈值，存储值小于它时返回 true"
                        },
                        "comparison": {
                            "type": "string",
                            "enum": [
                                "<",
                                ">",
                                "=",
                                "==",
                                "<=",
                                ">=",
                                "!=",
                                "<>",
                                "小于",
                                "大于",
                                "等于",
                                "小于等于",
                                "大于等于",
                                "不大于",
                                "不小于",
                                "不等于"
                            ],
                            "default": "<",
                            "description": "比较方式；配置值满足该比较时返回 true"
                        }
                    },
                    "required": ["key", "value"],
                    "additionalProperties": false
                }
            }
        },
        "ConfigValueWriteRecognition": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_recognition": {
                    "const": "ConfigValueWriteRecognition",
                    "description": "写入根目录 assets 下的 JSON，值统一按字符串保存"
                },
                "custom_recognition_param": {
                    "type": "object",
                    "properties": {
                        "key": {
                            "type": "string",
                            "description": "要写入的键名"
                        },
                        "value": {
                            "oneOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "number"
                                },
                                {
                                    "type": "integer"
                                }
                            ],
                            "description": "写入值；传入 add / sub 时会在当前值基础上加一 / 减一"
                        }
                    },
                    "required": ["key", "value"],
                    "additionalProperties": false
                }
            }
        },
        "TaskCounterRecognition": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_recognition": {
                    "const": "TaskCounterRecognition",
                    "description": "任务计数识别器，每次调用计数加一"
                },
                "custom_recognition_param": {
                    "type": "object",
                    "properties": {
                        "target_count": {
                            "type": "integer",
                            "minimum": 1,
                            "description": "目标次数"
                        }
                    },
                    "required": ["target_count"],
                    "additionalProperties": false
                }
            }
        },
        "MyRecognizer": {
            "properties": {
                "custom_recognition": {
                    "const": "MyRecognizer",
                    "description": "占位/测试识别器"
                }
            }
        }
    }
}
