{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "custom_action": {
            "enum": [
                "AutoBattle",
                "AutoFoster",
                "BonusToggleAction",
                "BountyMonsterRecognition",
                "ChallengeDungeonBoss",
                "CountAction",
                "Guess",
                "HumanTouch",
                "Kun28",
                "LoopAction",
                "QuestionMatcher",
                "RandomSwipe",
                "RandomTask",
                "RandomTouch",
                "RandomWait",
                "RepeatChallengeNTimes",
                "ReStart",
                "ReStartGame",
                "SwitchSoul",
                "TaskCounter",
                "TaskList",
                "TeamBuilder",
                "TimeCheck"
            ]
        }
    },
    "anyOf": [
        {
            "$ref": "#/$defs/AutoBattle"
        },
        {
            "$ref": "#/$defs/AutoFoster"
        },
        {
            "$ref": "#/$defs/BonusToggleAction"
        },
        {
            "$ref": "#/$defs/BountyMonsterRecognition"
        },
        {
            "$ref": "#/$defs/ChallengeDungeonBoss"
        },
        {
            "$ref": "#/$defs/CountAction"
        },
        {
            "$ref": "#/$defs/Guess"
        },
        {
            "$ref": "#/$defs/HumanTouch"
        },
        {
            "$ref": "#/$defs/Kun28"
        },
        {
            "$ref": "#/$defs/LoopAction"
        },
        {
            "$ref": "#/$defs/QuestionMatcher"
        },
        {
            "$ref": "#/$defs/RandomSwipe"
        },
        {
            "$ref": "#/$defs/RandomTask"
        },
        {
            "$ref": "#/$defs/RandomTouch"
        },
        {
            "$ref": "#/$defs/RandomWait"
        },
        {
            "$ref": "#/$defs/RepeatChallengeNTimes"
        },
        {
            "$ref": "#/$defs/ReStart"
        },
        {
            "$ref": "#/$defs/ReStartGame"
        },
        {
            "$ref": "#/$defs/SwitchSoul"
        },
        {
            "$ref": "#/$defs/TaskCounter"
        },
        {
            "$ref": "#/$defs/TaskList"
        },
        {
            "$ref": "#/$defs/TeamBuilder"
        },
        {
            "$ref": "#/$defs/TimeCheck"
        }
    ],
    "$defs": {
        "RequiredParam": {
            "anyOf": [
                {
                    "required": [
                        "custom_action_param"
                    ]
                },
                {
                    "required": [
                        "custom_action_param_code"
                    ]
                }
            ]
        },
        "AutoBattle": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_action": {
                    "const": "AutoBattle",
                    "description": "自动战斗，可选配置预设分组和队伍"
                },
                "custom_action_param": {
                    "type": "object",
                    "properties": {
                        "group_name": {
                            "type": "string",
                            "description": "预设分组名称"
                        },
                        "team_name": {
                            "type": "string",
                            "description": "预设队伍名称"
                        }
                    },
                    "additionalProperties": false
                }
            }
        },
        "AutoFoster": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_action": {
                    "const": "AutoFoster",
                    "description": "自动寄养（结界寄养）"
                },
                "custom_action_param": {
                    "type": "object",
                    "properties": {
                        "FosterTarget": {
                            "type": "integer",
                            "enum": [1, 2],
                            "default": 1,
                            "description": "1: 勾玉(默认), 2: 体力"
                        }
                    },
                    "additionalProperties": false
                }
            }
        },
        "BonusToggleAction": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_action": {
                    "const": "BonusToggleAction",
                    "description": "控制各种加成的开关状态"
                },
                "custom_action_param": {
                    "type": "object",
                    "properties": {
                        "exp_100%": {
                            "type": "boolean",
                            "description": "战斗胜利获得的经验增加100%"
                        },
                        "exp_50%": {
                            "type": "boolean",
                            "description": "战斗胜利获得的经验增加50%"
                        },
                        "gold_100%": {
                            "type": "boolean",
                            "description": "战斗胜利获得的金币增加100%"
                        },
                        "gold_50%": {
                            "type": "boolean",
                            "description": "战斗胜利获得的金币增加50%"
                        },
                        "drop_awake": {
                            "type": "boolean",
                            "description": "觉醒副本掉落额外的觉醒材料"
                        },
                        "drop_soul": {
                            "type": "boolean",
                            "description": "八岐大蛇掉落额外的御魂材料"
                        }
                    },
                    "additionalProperties": false
                }
            }
        },
        "BountyMonsterRecognition": {
            "properties": {
                "custom_action": {
                    "const": "BountyMonsterRecognition",
                    "description": "识别悬赏妖怪并开始探索"
                }
            }
        },
        "ChallengeDungeonBoss": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_action": {
                    "const": "ChallengeDungeonBoss",
                    "description": "自动挑战地鬼"
                },
                "custom_action_param": {
                    "type": "object",
                    "properties": {
                        "count": {
                            "type": "integer",
                            "minimum": 1,
                            "default": 1,
                            "description": "挑战地鬼数量"
                        }
                    },
                    "additionalProperties": false
                }
            }
        },
        "CountAction": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_action": {
                    "const": "CountAction",
                    "description": "计数动作，循环截图并运行指定的识别任务"
                },
                "custom_action_param": {
                    "type": "object",
                    "properties": {
                        "next_task": {
                            "type": "string",
                            "description": "达到目标计数后执行的下一个任务名"
                        },
                        "count_target": {
                            "type": "integer",
                            "minimum": 1,
                            "description": "目标计数次数"
                        },
                        "interval": {
                            "type": "number",
                            "default": 1.0,
                            "description": "每次识别之间的等待间隔（秒）"
                        },
                        "task_to_count": {
                            "type": "string",
                            "description": "要计数的识别任务名"
                        }
                    },
                    "required": ["next_task", "count_target", "task_to_count"],
                    "additionalProperties": false
                }
            }
        },
        "Guess": {
            "properties": {
                "custom_action": {
                    "const": "Guess",
                    "description": "竞猜动作，选择人数多的一方"
                }
            }
        },
        "HumanTouch": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_action": {
                    "const": "HumanTouch",
                    "description": "模拟人类点击行为"
                },
                "custom_action_param": {
                    "type": "object",
                    "properties": {
                        "ROI_1": {
                            "type": "array",
                            "items": {
                                "type": "integer"
                            },
                            "minItems": 4,
                            "maxItems": 4,
                            "default": [400, 520, 800, 600],
                            "description": "点击区域 [x, y, w, h]"
                        },
                        "short_wait_min": {
                            "type": "number",
                            "default": 1,
                            "description": "短等待最小时间(秒)"
                        },
                        "short_wait_max": {
                            "type": "number",
                            "default": 20,
                            "description": "短等待最大时间(秒)"
                        },
                        "long_wait_min": {
                            "type": "number",
                            "default": 100,
                            "description": "长等待最小时间(秒)"
                        },
                        "long_wait_max": {
                            "type": "number",
                            "default": 200,
                            "description": "长等待最大时间(秒)"
                        },
                        "short_wait_weight": {
                            "type": "number",
                            "default": 95,
                            "description": "短等待权重"
                        },
                        "long_wait_weight": {
                            "type": "number",
                            "default": 5,
                            "description": "长等待权重"
                        },
                        "single_click_weight": {
                            "type": "number",
                            "default": 50,
                            "description": "单击权重"
                        },
                        "double_click_weight": {
                            "type": "number",
                            "default": 50,
                            "description": "双击权重"
                        }
                    },
                    "additionalProperties": false
                }
            }
        },
        "Kun28": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_action": {
                    "const": "Kun28",
                    "description": "Kun28任务，进入探索后识别突破卷数量"
                },
                "custom_action_param": {
                    "type": "object",
                    "properties": {
                        "group_name": {
                            "type": "string",
                            "description": "预设分组名称"
                        },
                        "team_name": {
                            "type": "string",
                            "description": "预设队伍名称"
                        }
                    },
                    "additionalProperties": false
                }
            }
        },
        "LoopAction": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_action": {
                    "const": "LoopAction",
                    "description": "循环执行一系列动作"
                },
                "custom_action_param": {
                    "type": "object",
                    "properties": {
                        "action_list": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "minItems": 1,
                            "description": "要循环执行的动作名列表"
                        },
                        "loop_times": {
                            "type": "integer",
                            "minimum": 1,
                            "description": "循环次数"
                        },
                        "on_error": {
                            "type": "string",
                            "description": "出错时的处理策略"
                        }
                    },
                    "required": ["action_list", "loop_times"],
                    "additionalProperties": false
                }
            }
        },
        "QuestionMatcher": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_action": {
                    "const": "QuestionMatcher",
                    "description": "问题匹配动作，识别问题和答案"
                },
                "custom_action_param": {
                    "type": "object",
                    "properties": {
                        "upload": {
                            "type": "boolean",
                            "default": true,
                            "description": "是否上传"
                        },
                        "sync": {
                            "type": "boolean",
                            "default": true,
                            "description": "是否同步"
                        }
                    },
                    "additionalProperties": false
                }
            }
        },
        "RandomSwipe": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_action": {
                    "const": "RandomSwipe",
                    "description": "在指定区域内随机滑动"
                },
                "custom_action_param": {
                    "type": "object",
                    "properties": {
                        "start_roi": {
                            "type": "array",
                            "items": {
                                "type": "integer"
                            },
                            "minItems": 4,
                            "maxItems": 4,
                            "description": "起始区域 [x, y, w, h]"
                        },
                        "end_roi": {
                            "type": "array",
                            "items": {
                                "type": "integer"
                            },
                            "minItems": 4,
                            "maxItems": 4,
                            "description": "结束区域 [x, y, w, h]"
                        },
                        "delay": {
                            "type": "integer",
                            "default": 200,
                            "description": "滑动持续时间(毫秒)"
                        }
                    },
                    "required": ["start_roi", "end_roi"],
                    "additionalProperties": false
                }
            }
        },
        "RandomTask": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_action": {
                    "const": "RandomTask",
                    "description": "根据权重随机选择并执行一个任务"
                },
                "custom_action_param": {
                    "type": "object",
                    "description": "任务名到权重的映射，键为任务名称，值为权重（非负数）",
                    "additionalProperties": {
                        "type": "number",
                        "minimum": 0
                    }
                }
            }
        },
        "RandomTouch": {
            "properties": {
                "custom_action": {
                    "const": "RandomTouch",
                    "description": "在识别框区域内随机点击"
                }
            }
        },
        "RandomWait": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_action": {
                    "const": "RandomWait",
                    "description": "在指定时间范围内随机等待"
                },
                "custom_action_param": {
                    "type": "object",
                    "properties": {
                        "min": {
                            "description": "最小等待时间(秒)"
                        },
                        "max": {
                            "description": "最大等待时间(秒)"
                        }
                    },
                    "required": ["min", "max"],
                    "additionalProperties": false
                }
            }
        },
        "RepeatChallengeNTimes": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_action": {
                    "const": "RepeatChallengeNTimes",
                    "description": "设置自动挑战次数"
                },
                "custom_action_param": {
                    "type": "object",
                    "properties": {
                        "start_repeat": {
                            "type": "boolean",
                            "default": true,
                            "description": "是否启动自动挑战"
                        },
                        "expected_number": {
                            "type": "integer",
                            "default": 1,
                            "description": "期望的挑战次数"
                        }
                    },
                    "additionalProperties": false
                }
            }
        },
        "ReStart": {
            "properties": {
                "custom_action": {
                    "const": "ReStart",
                    "description": "超时重启动作"
                }
            }
        },
        "ReStartGame": {
            "properties": {
                "custom_action": {
                    "const": "ReStartGame",
                    "description": "重启游戏"
                }
            }
        },
        "SwitchSoul": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_action": {
                    "const": "SwitchSoul",
                    "description": "切换御魂预设"
                },
                "custom_action_param": {
                    "type": "object",
                    "properties": {
                        "group_name": {
                            "type": "string",
                            "description": "御魂预设分组名称"
                        },
                        "team_name": {
                            "type": "string",
                            "description": "御魂预设队伍名称"
                        }
                    },
                    "required": ["group_name", "team_name"],
                    "additionalProperties": false
                }
            }
        },
        "TaskCounter": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_action": {
                    "const": "TaskCounter",
                    "description": "任务计数器"
                },
                "custom_action_param": {
                    "type": "object",
                    "properties": {
                        "target_count": {
                            "type": "integer",
                            "minimum": 1,
                            "description": "目标次数"
                        }
                    },
                    "required": ["target_count"],
                    "additionalProperties": false
                }
            }
        },
        "TaskList": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_action": {
                    "const": "TaskList",
                    "description": "任务列表执行器"
                },
                "custom_action_param": {
                    "type": "object",
                    "properties": {
                        "tasks": {
                            "type": "object",
                            "description": "任务名到配置的映射",
                            "additionalProperties": {
                                "type": "object",
                                "properties": {
                                    "enabled": {
                                        "type": "boolean",
                                        "description": "是否启用该任务"
                                    },
                                    "once_per_day": {
                                        "type": "boolean",
                                        "description": "是否每天只执行一次"
                                    }
                                },
                                "additionalProperties": false
                            }
                        }
                    },
                    "required": ["tasks"],
                    "additionalProperties": false
                }
            }
        },
        "TeamBuilder": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_action": {
                    "const": "TeamBuilder",
                    "description": "组队通信，通过TCP Socket实现多机通信"
                },
                "custom_action_param": {
                    "type": "object",
                    "properties": {
                        "id": {
                            "type": "string",
                            "description": "本机标识ID"
                        },
                        "port": {
                            "type": "integer",
                            "description": "TCP通信端口"
                        }
                    },
                    "required": ["id", "port"],
                    "additionalProperties": false
                }
            }
        },
        "TimeCheck": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_action": {
                    "const": "TimeCheck",
                    "description": "时间+日期范围检查"
                },
                "custom_action_param": {
                    "type": "object",
                    "properties": {
                        "start": {
                            "type": "string",
                            "description": "开始时间，格式 \"15:04\" 或 \"15:04:05\""
                        },
                        "end": {
                            "type": "string",
                            "description": "结束时间，格式 \"15:04\" 或 \"15:04:05\""
                        },
                        "mode": {
                            "type": "string",
                            "enum": ["in", "out"],
                            "default": "in",
                            "description": "模式: in(在范围内返回true) 或 out(在范围外返回true)"
                        },
                        "date_rule": {
                            "type": "object",
                            "properties": {
                                "type": {
                                    "type": "string",
                                    "enum": ["none", "date", "dates", "month_day", "week"],
                                    "description": "日期规则类型"
                                },
                                "value": {
                                    "description": "规则值，根据type不同而不同"
                                }
                            },
                            "required": ["type"],
                            "additionalProperties": false
                        }
                    },
                    "required": ["start", "end"],
                    "additionalProperties": false
                }
            }
        }
    }
}