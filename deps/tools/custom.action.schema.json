        },
        {
            "$ref": "#/$defs/SOSSelectNoise"
        },
        {
            "$ref": "#/$defs/SOSSelectInstrument"
        },
        {
            "$ref": "#/$defs/SOSSelectNode"
        },
        {
            "$ref": "#/$defs/SOSNodeProcess"
        },
        {
            "$ref": "#/$defs/SOSSelectEncounterOption_OCR"
        },
